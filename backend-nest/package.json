{
  "name": "backend-nest",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "start:dev": "node -e \"require('fs').rmSync('dist/src',{recursive:true,force:true})\" && nest start --watch",
    "prebuild": "prisma generate --schema=./prisma/schema.prisma",
    "build": "nest build",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma",
    "test": "jest --config jest.config.js"
  },
  "prisma": {
    "schema": "./prisma/schema.prisma",
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "^6.7.0",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "neo4j-driver": "^5.28.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.22",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.9.0",
    "@types/passport-jwt": "^4.0.1",
    "jest": "^30.4.2",
    "prisma": "^6.7.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}
